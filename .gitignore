# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# contact form & blog data (contains personal data — do not commit)
/data/submissions.json
/data/read-counts.json
/data/admins.json

# nightly publish logs
/logs/*.log

# word files in drop folder (processed by import-blog script)
/upload blog - word file only/*.docx
/upload blog - word file only/*.doc
/upload blog - word file only/processed/
